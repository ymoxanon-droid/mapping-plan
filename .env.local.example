# Supabase — dipakai client (anon key aman di browser selama RLS aktif)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Kode akses admin panel (UX-gate, bukan security — ke-bundle ke JS client)
VITE_ADMIN_CODE=

# Dipakai hanya oleh scripts/seed.ts (server-side, jangan di-expose ke client)
SUPABASE_SERVICE_ROLE_KEY=
